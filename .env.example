# --- Web tools (always required) ---
SERPER_API_KEY=          # web search — https://serper.dev
FIRECRAWL_API_KEY=       # web scraping — https://firecrawl.dev

# --- Which brain runs the reasoning ---
# Default is a FREE LOCAL model via Ollama (no key, no credits). Just install Ollama
# (https://ollama.com) and `ollama pull qwen2.5:7b`. Nothing else needed here.
LLM_PROVIDER=ollama
# DR_OLLAMA_MODEL=qwen2.5:7b
# OLLAMA_HOST=http://localhost:11434

# To use a cloud model instead, set LLM_PROVIDER above to "anthropic" or "openai"
# and provide the matching key:
# ANTHROPIC_API_KEY=        # if LLM_PROVIDER=anthropic — https://console.anthropic.com
# OPENAI_API_KEY=           # if LLM_PROVIDER=openai (also works with Groq via OPENAI_BASE_URL)
# OPENAI_BASE_URL=https://api.openai.com/v1
# DR_OPENAI_MODEL=gpt-4o-mini

# --- Optional tuning ---
# DR_MAX_SOURCES=55
# DR_SOURCE_CHARS=24000
# DR_OUTPUT_DIR=reports
# REPORT_FONT=/path/to/a/font.ttf
