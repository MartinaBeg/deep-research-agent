# Web tools (the only keys needed — these are NOT LLM/model keys).
# The reasoning is done by whatever coding-agent tool runs this (Claude Code, Codex, ...),
# using its own model. No LLM API key, no credits.

SERPER_API_KEY=          # web search — https://serper.dev
FIRECRAWL_API_KEY=       # web scraping — https://firecrawl.dev

# Optional: a Unicode TTF for nicer PDFs (otherwise a system/default font is used).
# REPORT_FONT=/path/to/a/font.ttf
