# Web tools used by the grounded-research agent (these are NOT Anthropic keys).
# The reasoning runs on your Claude Code subscription, so no Anthropic API key is needed.

# Serper — web search (https://serper.dev)
SERPER_API_KEY=

# Firecrawl — web scraping (https://firecrawl.dev)
FIRECRAWL_API_KEY=

# Optional: path to a Unicode TTF font for nicer PDFs (defaults to a system font).
# REPORT_FONT=/System/Library/Fonts/Supplemental/Georgia.ttf
